# Server
PORT=3000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/ecommerce

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this

# Cloudinary (image uploads) — get from cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (SMTP) — works with Gmail, SendGrid, Mailgun, etc.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=My Store

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:3000

# Refresh Token Secret (must be different from JWT_SECRET)
JWT_REFRESH_SECRET=your_refresh_token_secret_different_from_jwt_secret
